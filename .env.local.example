# Resend — transactional e-mail voor lead-notificaties.
# Maak een API key aan op https://resend.com/api-keys
RESEND_API_KEY=

# Ontvanger van lead-notificaties (intern team).
LEAD_NOTIFICATION_EMAIL=bookings@courtside.nl

# Afzender-adres. Default is Resend's test-afzender (werkt zonder
# domeinverificatie). Vervang door 'Courtside <leads@courtside.nl>'
# zodra courtside.nl in Resend is geverifieerd.
RESEND_FROM_EMAIL=Courtside <onboarding@resend.dev>
